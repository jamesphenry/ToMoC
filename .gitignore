# --- Python ---
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/

# --- Virtual env (huge, regenerable from requirements.lock.txt) ---
.venv/
venv/

# --- Model weights (download or train; never commit) ---
models/
*.bin
*.safetensors
*.gguf
*.pt
*.pth

# --- Generated / runtime artifacts ---
adapters/
logs/
data/processed/
benchmarks/*.json
benchmarks/*.csv
benchmarks/*.db
.ipynb_checkpoints/

# --- Podcast audio (local-only: 133MB of .m4a, don't bloat git/mirrors) ---
# player.html + pod/README.md ARE committed; the audio is referenced by path.
pod/*.m4a

# --- OS / editor ---
.DS_Store
*.swp
